{
  "name": "speakeasy",
  "private": true,
  "scripts": {
    "dev": "npm run dev --prefix web",
    "build": "npm run build --prefix web",
    "build:functions": "npm run build --prefix functions",
    "emulate": "firebase emulators:start --project demo-speakeasy",
    "emulate:import": "firebase emulators:start --project demo-speakeasy --import .emulator-data --export-on-exit",
    "deploy": "npm run build && npm run build:functions && firebase deploy",
    "seed:prod": "node scripts/seed-emulator.mjs --prod",
    "generate:images": "node --env-file=.env scripts/generate-drink-images.mjs"
  },
  "devDependencies": {
    "openai": "^6.46.0",
    "sharp": "^0.35.3"
  }
}
