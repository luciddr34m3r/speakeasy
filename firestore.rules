rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null &&
             request.auth.uid == get(/databases/$(database)/documents/config/app).data.adminUid;
    }

    // Drinks: available drinks are publicly readable; admin can read/write all
    match /drinks/{drinkId} {
      allow read: if resource.data.available == true || isAdmin();
      allow write: if isAdmin();
    }

    // Orders: any authenticated user (anon included) can create their own order;
    //         read is restricted to the order owner or admin;
    //         status updates are admin-only
    match /orders/{orderId} {
      allow create: if request.auth != null &&
                       request.resource.data.guestUid == request.auth.uid;
      allow read: if request.auth != null &&
                     (resource.data.guestUid == request.auth.uid || isAdmin());
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // User profiles: users can only read/write their own profile
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // App config: anyone authenticated can read (for partyMode, adminUid check);
    //             only admin can write
    match /config/app {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
  }
}
