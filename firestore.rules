rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null &&
             request.auth.uid == get(/databases/$(database)/documents/config/app).data.adminUid;
    }

    // Staff = the admin or an invited guest bartender
    function isStaff() {
      return request.auth != null &&
             (request.auth.uid == get(/databases/$(database)/documents/config/app).data.adminUid ||
              request.auth.uid in get(/databases/$(database)/documents/config/app).data.get('bartenderUids', []));
    }

    // Drinks: available drinks are publicly readable; staff can read/write all
    match /drinks/{drinkId} {
      allow read: if resource.data.available == true || isStaff();
      allow write: if isStaff();
    }

    // Orders: created only by the createOrder Cloud Function (Admin SDK bypasses
    //         these rules) — no client-side creation;
    //         read is restricted to the order owner or admin;
    //         updates are admin-only, except the owner may cancel while 'received'
    match /orders/{orderId} {
      allow read: if request.auth != null &&
                     (resource.data.guestUid == request.auth.uid || isStaff());
      allow update: if isStaff() ||
                       (request.auth != null &&
                        resource.data.guestUid == request.auth.uid &&
                        resource.data.status == 'received' &&
                        request.resource.data.status == 'cancelled' &&
                        request.resource.data.diff(resource.data).affectedKeys()
                          .hasOnly(['status', 'cancelledAt']));
      allow delete: if isStaff();
    }

    // User profiles: users can only read/write their own profile
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // App config: publicly readable — the theme and bar status must render
    //             before anonymous sign-in completes (fresh/incognito visits).
    //             Nothing secret lives here (secrets go in config/private).
    //             Admin can write anything, guest bartenders only the
    //             bar-operations fields (never the staff/token lists).
    match /config/app {
      allow read: if true;
      allow write: if isAdmin();
      allow update: if isStaff() &&
                       request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['partyMode', 'barOpen', 'barOpenedAt', 'theme']);
    }

    // Staff secrets — the door password lives here so guests can't read it
    match /config/private {
      allow read, write: if isStaff();
    }
  }
}
