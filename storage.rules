rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Drink photos are publicly readable; staff (admin + guest bartenders) can write
    match /drinks/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null &&
                      (request.auth.uid == firestore.get(/databases/(default)/documents/config/app).data.adminUid ||
                       request.auth.uid in firestore.get(/databases/(default)/documents/config/app).data.get('bartenderUids', []));
    }
  }
}
