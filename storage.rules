rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Drink photos are publicly readable
    match /drinks/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null &&
                      request.auth.uid == firestore.get(/databases/(default)/documents/config/app).data.adminUid;
    }
  }
}
